DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-chat

# 图片识别用的 vision 模型（需支持多模态，如 gpt-4o）
# 默认使用 DEEPSEEK_API_KEY 和 DEEPSEEK_BASE_URL
VISION_MODEL=deepseek-chat

EMBEDDING_MODEL_NAME=./models/bge-m3
HF_ENDPOINT=https://hf-mirror.com

MAX_CHAT_CONCURRENCY=50
CHAT_QUEUE_TIMEOUT=30
CHAT_STREAM_CHUNK_SIZE=20
CHAT_STREAM_PING_INTERVAL=0.6

BACKEND_BASE_URL=http://127.0.0.1:8000
