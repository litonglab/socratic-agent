        <mxCell id="11" value="图5-2 典型案例对照：PC ping不通排查" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#0F172A;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="68" y="48" width="900" height="32" as="geometry"/>
        </mxCell>
        <mxCell id="12" value="实验一目的：通过典型案例比较 Agent 与纯 DeepSeek 在网络实验教学中的课程贴合度、交互组织方式与教学引导效果。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12.5;fontColor=#475569;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="68" y="82" width="1380" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="13" value="&lt;b&gt;问题：&lt;/b&gt;我在实验1里，两台 PC 的 IP 地址都配好了，但是 ping 不通，怎么回事？" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontColor=#1F2937;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="68" y="106" width="1420" height="22" as="geometry"/>
        </mxCell>

        <mxCell id="20" value="" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FCF6F7;strokeColor=#E6B8BF;strokeWidth=1.8;" vertex="1" parent="1">
          <mxGeometry x="40" y="172" width="900" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="21" value="" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#F5F8FD;strokeColor=#B4C7E7;strokeWidth=1.8;" vertex="1" parent="1">
          <mxGeometry x="975" y="172" width="585" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="22" value="" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#D8DDE6;strokeWidth=1.4;" vertex="1" parent="1">
          <mxGeometry x="40" y="818" width="1520" height="170" as="geometry"/>
        </mxCell>

        <mxCell id="30" value="Agent（多轮引导）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=19;fontStyle=1;fontColor=#C44E52;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="66" y="194" width="260" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="31" value="总耗时 135.1s　Hint 轨迹 0 → 0 → 3" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12.5;fontColor=#4B5563;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="66" y="226" width="360" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="32" value="准确性 5　引导性 4　递进性 5　完整性 4" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12.5;fontColor=#4B5563;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="66" y="248" width="380" height="22" as="geometry"/>
        </mxCell>

        <mxCell id="33" value="DeepSeek（单轮直答）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=19;fontStyle=1;fontColor=#4C72B0;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="1005" y="194" width="280" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="34" value="单轮耗时 52.8s　回答字数 2207" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12.5;fontColor=#4B5563;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="1005" y="226" width="320" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="35" value="准确性 5　引导性 4　递进性 4　完整性 5" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12.5;fontColor=#4B5563;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="1005" y="248" width="360" height="22" as="geometry"/>
        </mxCell>

        <mxCell id="40" value="" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#C44E52;strokeColor=#C44E52;" vertex="1" parent="1">
          <mxGeometry x="66" y="284" width="16" height="134" as="geometry"/>
        </mxCell>
        <mxCell id="41" value="&lt;b&gt;第 1 轮｜hint=0｜95.8s｜工具：检索&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px;color:#475569;&quot;&gt;学生：提出“IP 已配置但 ping 不通”的初始故障现象。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;Agent：先从 PC 自身的常见设置切入，引导学生检查 ICMPv4-In 防火墙规则。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#DDA2AB;strokeWidth=1.4;fontSize=13;fontColor=#1F2937;spacingTop=8;spacingLeft=18;spacingRight=10;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="82" y="284" width="832" height="134" as="geometry"/>
        </mxCell>

        <mxCell id="42" value="" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#C44E52;strokeColor=#C44E52;" vertex="1" parent="1">
          <mxGeometry x="66" y="448" width="16" height="118" as="geometry"/>
        </mxCell>
        <mxCell id="43" value="&lt;b&gt;第 2 轮｜hint=0｜19.3s｜工具：未调用&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px;color:#475569;&quot;&gt;学生：确认网线插紧，但没有回答上一轮的防火墙状态。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;Agent：不重复追问概念，转向检查网络接口的链路状态。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#DDA2AB;strokeWidth=1.4;fontSize=13;fontColor=#1F2937;spacingTop=8;spacingLeft=18;spacingRight=10;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="82" y="448" width="832" height="118" as="geometry"/>
        </mxCell>

        <mxCell id="44" value="" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#C44E52;strokeColor=#C44E52;" vertex="1" parent="1">
          <mxGeometry x="66" y="596" width="16" height="144" as="geometry"/>
        </mxCell>
        <mxCell id="45" value="&lt;b&gt;第 3 轮｜hint=3｜20.0s｜工具：未调用&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px;color:#475569;&quot;&gt;学生：表示已打开防火墙界面，但不知道具体应该修改哪里。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;Agent：在高 Hint 下给出最小可执行步骤，并要求继续上报 ipconfig 的 IPv4 与子网掩码结果。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#DDA2AB;strokeWidth=1.4;fontSize=13;fontColor=#1F2937;spacingTop=8;spacingLeft=18;spacingRight=10;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="82" y="596" width="832" height="144" as="geometry"/>
        </mxCell>

        <mxCell id="46" value="学生反馈" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;exitX=0.5;exitY=1;strokeWidth=1.6;strokeColor=#C44E52;fontSize=12;labelBackgroundColor=#FCF6F7;fontFamily=Songti SC;" edge="1" parent="1" source="41" target="43">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="47" value="继续追问" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;exitX=0.5;exitY=1;strokeWidth=1.6;strokeColor=#C44E52;fontSize=12;labelBackgroundColor=#FCF6F7;fontFamily=Songti SC;" edge="1" parent="1" source="43" target="45">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="50" value="" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#98B1DA;strokeWidth=1.4;" vertex="1" parent="1">
          <mxGeometry x="1010" y="284" width="515" height="126" as="geometry"/>
        </mxCell>
        <mxCell id="51" value="&lt;b&gt;回答组织方式&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;单轮给出系统化排查清单，围绕 PC 配置、链路状态和中间设备依次展开。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#98B1DA;strokeWidth=1.4;fontSize=13;fontColor=#1F2937;spacingTop=10;spacingLeft=16;spacingRight=12;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="1010" y="284" width="515" height="126" as="geometry"/>
        </mxCell>

        <mxCell id="52" value="&lt;b&gt;一次性覆盖内容&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;IP / 子网掩码、默认网关、防火墙、线缆与接口状态、交换机 / 路由器配置、ARP、tracert 等诊断工具。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#98B1DA;strokeWidth=1.4;fontSize=13;fontColor=#1F2937;spacingTop=10;spacingLeft=16;spacingRight=12;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="1010" y="430" width="515" height="138" as="geometry"/>
        </mxCell>

        <mxCell id="53" value="&lt;b&gt;特点&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;信息完整、覆盖面广，但集中释放较多内容；课程专属证据链较弱。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#98B1DA;strokeWidth=1.4;fontSize=13;fontColor=#1F2937;spacingTop=10;spacingLeft=16;spacingRight=12;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="1010" y="588" width="515" height="116" as="geometry"/>
        </mxCell>

        <mxCell id="60" value="案例观察" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=17;fontStyle=1;fontColor=#1F2937;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="60" y="838" width="180" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="61" value="&lt;b&gt;交互组织&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;color:#C44E52;font-size:12px;&quot;&gt;Agent：三轮递进式引导，依据学生反馈切换排查焦点。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;color:#4C72B0;font-size:12px;&quot;&gt;DeepSeek：单轮集中输出完整排查清单。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FBFBFC;strokeColor=#D7DBE2;strokeWidth=1.2;fontSize=13;fontColor=#1F2937;spacingTop=8;spacingLeft=12;spacingRight=10;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="60" y="870" width="335" height="92" as="geometry"/>
        </mxCell>
        <mxCell id="62" value="&lt;b&gt;课程证据&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;color:#C44E52;font-size:12px;&quot;&gt;Agent：调用课程检索并引用实验材料。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;color:#4C72B0;font-size:12px;&quot;&gt;DeepSeek：无课程专属检索与拓扑证据链。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FBFBFC;strokeColor=#D7DBE2;strokeWidth=1.2;fontSize=13;fontColor=#1F2937;spacingTop=8;spacingLeft=12;spacingRight=10;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="435" y="870" width="335" height="92" as="geometry"/>
        </mxCell>
        <mxCell id="63" value="&lt;b&gt;教学策略&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;color:#C44E52;font-size:12px;&quot;&gt;Agent：先定位关键检查点，再纠偏，最后在高 Hint 下收敛。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;color:#4C72B0;font-size:12px;&quot;&gt;DeepSeek：直接给整体路径，引导过程较弱。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FBFBFC;strokeColor=#D7DBE2;strokeWidth=1.2;fontSize=13;fontColor=#1F2937;spacingTop=8;spacingLeft=12;spacingRight=10;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="810" y="870" width="335" height="92" as="geometry"/>
        </mxCell>
        <mxCell id="64" value="&lt;b&gt;工程代价&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;color:#C44E52;font-size:12px;&quot;&gt;Agent：135.1s，回答总长 2088 字。&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;color:#4C72B0;font-size:12px;&quot;&gt;DeepSeek：52.8s，回答长度 2207 字。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FBFBFC;strokeColor=#D7DBE2;strokeWidth=1.2;fontSize=13;fontColor=#1F2937;spacingTop=8;spacingLeft=12;spacingRight=10;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="1185" y="870" width="335" height="92" as="geometry"/>
        </mxCell>

        <mxCell id="70" value="数据来源：eval/results/demo_20260313_124512.json（场景 1）" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;fontSize=11.5;fontColor=#6B7280;fontFamily=Songti SC;" vertex="1" parent="1">
          <mxGeometry x="1130" y="962" width="390" height="18" as="geometry"/>
        </mxCell>
      </root>
