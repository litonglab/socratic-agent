        <mxCell id="10" value="" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#F5F6F8;strokeColor=#D8DDE6;strokeWidth=1.6;" vertex="1" parent="1">
          <mxGeometry x="40" y="32" width="1520" height="110" as="geometry"/>
