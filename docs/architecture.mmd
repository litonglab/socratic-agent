%%{ init: { "theme": "base", "themeVariables": { "fontSize": "14px" } } }%%
flowchart LR
    USER(("用户"))

    subgraph 前端
        ST["Streamlit UI"]
        OCR["Vision / OCR"]
    end

    subgraph 后端
        API["FastAPI 服务"]
    end

    subgraph Agent编排层
        CLASSIFY["统一分类"]
        HINT["Hint 等级决策"]
        PROMPT["Prompt 构建"]
        LOOP["Agent 循环\n(最多5轮)"]
    end

    subgraph 工具层
        RAG["RAG 检索"]
        TOPO["拓扑查询"]
        WEB["Web 搜索"]
    end

    subgraph 知识与数据
        FAISS[("FAISS\n向量库")]
        TOPOSTORE[("拓扑存储")]
        SQLITE[("SQLite")]
        PROF["学力评估"]
    end

    subgraph 外部服务
        DEEPSEEK["DeepSeek API"]
        HF["BGE-M3\n+ Reranker"]
        DDG["DuckDuckGo"]
    end

    %% ── 主流程 ──
    USER -->|"提问"| ST
    ST -->|"图片"| OCR
    OCR -->|"文本"| ST
    ST --> API
    API --> CLASSIFY --> HINT --> PROMPT --> LOOP

    %% ── 工具调用 ──
    LOOP -->|"检索"| RAG
    LOOP -->|"拓扑"| TOPO
    LOOP -->|"搜索"| WEB

    %% ── LLM ──
    LOOP <-->|"LLM 调用"| DEEPSEEK

    %% ── 数据层 ──
    RAG --> FAISS
    RAG -->|"精排"| HF
    TOPO --> TOPOSTORE
    WEB --> DDG
    API -->|"持久化"| SQLITE
    SQLITE <--> PROF

    %% ── 返回 ──
    LOOP -->|"回答"| API -->|"SSE 流"| ST -->|"渲染"| USER

    %% ── 样式 ──
    classDef fe fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f
    classDef be fill:#d1fae5,stroke:#10b981,color:#064e3b
    classDef orch fill:#ffedd5,stroke:#f97316,color:#7c2d12
    classDef tool fill:#ede9fe,stroke:#8b5cf6,color:#3b0764
    classDef data fill:#fef9c3,stroke:#eab308,color:#713f12
    classDef ext fill:#f3f4f6,stroke:#6b7280,color:#374151,stroke-dasharray:5 5

    class ST,OCR fe
    class API be
    class CLASSIFY,HINT,PROMPT,LOOP orch
    class RAG,TOPO,WEB tool
    class FAISS,TOPOSTORE,SQLITE,PROF data
    class DEEPSEEK,HF,DDG ext
