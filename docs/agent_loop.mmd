%%{ init: { "theme": "base", "themeVariables": { "fontSize": "14px" } } }%%
flowchart TD
    START(("用户消息"))

    REL{"相关性检查"}
    GENERAL["通用回答"] --> DONE

    CLASSIFY["统一分类"]

    subgraph 四类问题
        LAB["实验排障"]
        THEORY["理论概念"]
        CONFIG["配置审查"]
        CALC["计算分析"]
    end

    HINT["Hint 等级决策\n0‑3 级"]
    PROMPT["构建系统提示"]
    LLM["LLM 调用"]

    HAS_TOOL{"有工具调用?"}

    subgraph 工具执行
        T_RAG["检索"]
        T_TOPO["拓扑"]
        T_WEB["搜索"]
    end

    STREAM["流式输出回答"]
    PERSIST["后台持久化\n会话 · 指标 · 学力"]
    DONE(("完成"))

    %% ── 流程 ──
    START --> REL
    REL -->|"不相关"| GENERAL
    REL -->|"相关"| CLASSIFY
    CLASSIFY --> LAB & THEORY & CONFIG & CALC
    LAB & THEORY & CONFIG & CALC --> HINT --> PROMPT --> LLM
    LLM --> HAS_TOOL
    HAS_TOOL -->|"否"| STREAM
    HAS_TOOL -->|"是"| T_RAG & T_TOPO & T_WEB
    T_RAG & T_TOPO & T_WEB -->|"结果回传"| LLM
    STREAM --> PERSIST --> DONE

    %% ── 样式 ──
    classDef decision fill:#fef3c7,stroke:#f59e0b,color:#78350f
    classDef process fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f
    classDef tool fill:#ede9fe,stroke:#8b5cf6,color:#3b0764
    classDef persist fill:#d1fae5,stroke:#10b981,color:#064e3b
    classDef cat fill:#ffedd5,stroke:#f97316,color:#7c2d12

    class REL,HAS_TOOL decision
    class CLASSIFY,HINT,PROMPT,LLM,STREAM,GENERAL process
    class T_RAG,T_TOPO,T_WEB tool
    class PERSIST persist
    class LAB,THEORY,CONFIG,CALC cat
